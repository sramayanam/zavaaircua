          <mxGeometry height="37.13053074093536" width="37.13053074093536" y="135.20946925906466" as="geometry" />
        </mxCell>
        <mxCell id="0o9W3yOrl1AGczE6vrlX-84" parent="0o9W3yOrl1AGczE6vrlX-103" style="aspect=fixed;strokeColor=#6c8ebf;shadow=0;fillColor=#dae8fc;verticalAlign=top;labelPosition=center;verticalLabelPosition=bottom;shape=mxgraph.gcp2.play_gear;fontSize=11;rounded=1;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fontStyle=0;fontFamily=Times New Roman;" value="Clear&#xa;Payload" vertex="1">
          <mxGeometry height="27.168681029952708" width="27.168681029952708" x="129.26446840156697" as="geometry" />
        </mxCell>
        <mxCell id="0o9W3yOrl1AGczE6vrlX-85" edge="1" parent="0o9W3yOrl1AGczE6vrlX-103" source="0o9W3yOrl1AGczE6vrlX-39" style="rounded=0;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;orthogonalLoop=1;jettySize=auto;entryX=0.11;entryY=0.68;entryDx=0;entryDy=0;entryPerimeter=0;strokeColor=#788AA3;fontFamily=Times New Roman;fontColor=#46495D;fillColor=#B2C9AB;fontSize=11;fontStyle=0" target="0o9W3yOrl1AGczE6vrlX-84" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="0o9W3yOrl1AGczE6vrlX-108" parent="0o9W3yOrl1AGczE6vrlX-86" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=middle;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;gradientColor=#b3b3b3;" value="&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;u&gt;Ingest&lt;/u&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;A file upload to Blob Storage triggers Event Grid, which invokes the Logic App Orchestrator through a webhook.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;u&gt;Orchestrate&lt;/u&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;The Orchestrator parses the payload, validates primary/foreign key constraints, checks relationships, and records the transaction in the Load Table for auditing.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;u&gt;Queue&lt;/u&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Validated jobs are routed through the Complaints Agent Endpoint → Compute Layer → Payload Queue for processing.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Process&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Each job is dequeued and its status is recorded in the Job Table.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;The Process Job step then attempts execution with retry logic.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;u&gt;Automate&lt;/u&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;On successful job initiation, the Browser Automation Task loads the complaints webpage and runs the CUA loop:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Take Screenshot&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Send to Computer Use Preview Model&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Execute Playwright Action&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Repeat&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;The loop exits when no computer_call is returned or the maximum iteration limit is reached.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;u&gt;Resolve&lt;/u&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Successful jobs clear the Payload Queue.&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Failed jobs (after retries) are written to the Dead Letter Queue for further review.&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="358" width="392.7" x="-1.4000000000000004" y="278" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
